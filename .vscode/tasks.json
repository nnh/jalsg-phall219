{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "next-action.md を開く",
      "type": "shell",
      "command": "bash",
      "args": ["${workspaceFolder}/scripts/open-next-action.sh"],
      "windows": {
        "command": "powershell",
        "args": [
          "-NoProfile",
          "-Command",
          "Start-Process '${workspaceFolder}\\next-action.md'"
        ]
      },
      "presentation": {
        "reveal": "silent",
        "panel": "shared",
        "close": true
      },
      "problemMatcher": [],
      "runOptions": {
        "runOn": "folderOpen"
      }
    }
  ]
}
